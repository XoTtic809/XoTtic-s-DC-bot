# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this to .env for local development.
# NEVER commit .env to version control.
# On Railway, set these in the "Variables" tab — they override appsettings.json.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Your Discord bot token. Found at https://discord.com/developers/applications
# → Your App → Bot → Token
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# PostgreSQL connection string (Railway format: postgresql://user:pass@host:port/db)
# Railway auto-sets this when you add a PostgreSQL plugin to your service.
DATABASE_URL=postgresql://user:password@localhost:5432/discord_key_bot

# ID of the Discord text channel where audit logs are posted.
# Enable Developer Mode in Discord (Settings → Advanced), then right-click
# the channel and choose "Copy Channel ID".
LOG_CHANNEL_ID=123456789012345678

# ── Optional ──────────────────────────────────────────────────────────────────

# Set this to a specific guild (server) ID for instant slash command registration.
# Leave unset (or set to empty) for global registration (1-hour propagation delay).
# Right-click your server icon in Discord (Developer Mode must be enabled).
Bot__GuildId=

# Override the admin role name if your server uses a different name.
# Default: "Admin"
Bot__AdminRoleName=Admin

# ASP.NET Core environment. Set to "Production" on Railway.
ASPNETCORE_ENVIRONMENT=Production

# Railway sets PORT automatically. Only override if self-hosting.
# PORT=8080
