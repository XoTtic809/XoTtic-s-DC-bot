{
  // ─────────────────────────────────────────────────────────────────────────
  // appsettings.json — Base configuration for all environments.
  //
  // All secrets (Token, DatabaseUrl, LogChannelId) should be set via
  // environment variables in production. The values here are safe defaults
  // for local development only. Never commit real tokens here.
  // ─────────────────────────────────────────────────────────────────────────
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },

  // ── Bot Configuration ────────────────────────────────────────────────────
  // Override any of these via environment variable: Bot__Token, Bot__GuildId, etc.
  // Railway injects DISCORD_TOKEN and LOG_CHANNEL_ID as top-level env vars;
  // ServiceCollectionExtensions.AddDiscordBot() reads both conventions.
  "Bot": {
    "Token": "",
    "GuildId": null,
    "LogChannelId": 0,
    "AdminRoleName": "Admin"
  },

  // ── Database ─────────────────────────────────────────────────────────────
  // For local development only. In production, set DATABASE_URL env var.
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=discord_key_bot;Username=postgres;Password=postgres"
  },

  // ── ASP.NET Core ─────────────────────────────────────────────────────────
  "AllowedHosts": "*",

  // Kestrel listens on PORT env var when deployed to Railway.
  // Railway sets PORT automatically; this section ensures fallback to 8080.
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      }
    }
  }
}
